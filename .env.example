# DevPortal Configuration
# Copy to .env and fill in values

# Server
PORT=3000
NODE_ENV=production

# Auth
PORTAL_JWT_SECRET=changeme-use-a-random-64-char-string
PORTAL_ADMIN_EMAIL=admin@portal.local
PORTAL_ADMIN_PASSWORD=changeme

# Coolify API (accessible via Docker network)
COOLIFY_API_URL=http://coolify:8080/api/v1
COOLIFY_API_TOKEN=your-coolify-api-token

# Uptime Kuma (accessible via Docker network)
UPTIME_KUMA_URL=http://uptime-kuma:3001
UPTIME_KUMA_USERNAME=admin
UPTIME_KUMA_PASSWORD=changeme

# Data directory (SQLite database)
DATA_DIR=/app/data

# OIDC / Authentik SSO
OIDC_ISSUER=https://authentik.example.com/application/o/devportal/
OIDC_ISSUER_INTERNAL=http://authentik-server:9000/application/o/devportal/
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=https://portal.example.com/api/auth/callback
SESSION_SECRET=changeme-use-a-random-64-char-string
PORTAL_URL=https://portal.example.com
